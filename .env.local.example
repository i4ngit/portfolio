# Copy this file to .env.local and fill in values

# Admin password (bcrypt hash) — generate with: node -e "const bcrypt=require('bcryptjs'); bcrypt.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Session secret — any long random string, e.g.: openssl rand -base64 32
SESSION_SECRET=

# Vercel KV — auto-populated when you add KV to your Vercel project
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
