# Copy this file to .env.local and fill in values

# Admin password (bcrypt hash) — generate with:
# node -e "const bcrypt=require('bcryptjs'); bcrypt.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Session secret — any long random string, e.g.: openssl rand -base64 32
SESSION_SECRET=

# Upstash Redis — from Vercel dashboard → Integrations → Upstash Redis → .env.local
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
